<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:key="privacy"
        android:title="@string/privacy">

        <SwitchPreference
            android:key="javascript_enabled"
            android:title="@string/javascript_preference"
            android:summary="@string/javascript_preference_summary"
            android:defaultValue="false" />

        <SwitchPreference
            android:key="first_party_cookies_enabled"
            android:title="@string/first_party_cookies_preference"
            android:summary="@string/first_party_cookies_preference_summary"
            android:defaultValue="false" />

        <SwitchPreference
            android:key="third_party_cookies_enabled"
            android:title="@string/third_party_cookies_preference"
            android:summary="@string/third_party_cookies_summary"
            android:defaultValue="false" />

        <SwitchPreference
            android:key="dom_storage_enabled"
            android:title="@string/dom_storage_preference"
            android:summary="@string/dom_storage_preference_summary"
            android:defaultValue="false" />

        <ListPreference
            android:key="user_agent"
            android:title="@string/user_agent"
            android:entries="@array/user_agent_entries"
            android:entryValues="@array/user_agent_entry_values"
            android:defaultValue="Default user agent" />

        <EditTextPreference
            android:key="custom_user_agent"
            android:title="@string/custom_user_agent"
            android:defaultValue="VionBrowser/1.0"
            android:inputType="textVisiblePassword|textMultiLine" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="search"
        android:title="@string/search">

        <ListPreference
            android:key="javascript_disabled_search"
            android:title="@string/javascript_disabled_search"
            android:entries="@array/javascript_disabled_search_entries"
            android:entryValues="@array/javascript_disabled_search_entry_values"
            android:defaultValue="https://duckduckgo.com/html/?q=" />

        <EditTextPreference
            android:key="javascript_disabled_search_custom_url"
            android:title="@string/javascript_disabled_search_custom_url"
            android:defaultValue=""
            android:inputType="textUri" />

        <ListPreference
            android:key="javascript_enabled_search"
            android:title="@string/javascript_enabled_search"
            android:entries="@array/javascript_enabled_search_entries"
            android:entryValues="@array/javascript_enabled_search_entry_values"
            android:defaultValue="https://duckduckgo.com/?q=" />

        <EditTextPreference
            android:key="javascript_enabled_search_custom_url"
            android:title="@string/javascript_enabled_search_custom_url"
            android:defaultValue=""
            android:inputType="textUri" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="general"
        android:title="@string/general">

        <EditTextPreference
            android:key="homepage"
            android:title="@string/homepage_preference"
            android:defaultValue="https://duckduckgo.com"
            android:inputType="textUri" />

        <SwitchPreference
            android:key="swipe_to_refresh_enabled"
            android:title="@string/swipe_to_refresh_enabled"
            android:summary="@string/swipe_to_refresh_enabled_summary"
            android:defaultValue="true" />

    </PreferenceCategory>

    <!-- Phase 8 — Security additions -->
    <PreferenceCategory
        android:key="security"
        android:title="@string/security">

        <SwitchPreference
            android:key="fingerprint_resistance"
            android:title="@string/fingerprint_resistance"
            android:summary="@string/fingerprint_resistance_summary"
            android:defaultValue="true" />

        <SwitchPreference
            android:key="page_visibility_spoof"
            android:title="@string/page_visibility_spoof"
            android:summary="@string/page_visibility_spoof_summary"
            android:defaultValue="true" />

        <SwitchPreference
            android:key="strip_tracking_params"
            android:title="@string/strip_tracking_params"
            android:summary="@string/strip_tracking_params_summary"
            android:defaultValue="true" />

        <SwitchPreference
            android:key="https_only_mode"
            android:title="@string/https_only_mode"
            android:summary="@string/https_only_mode_summary"
            android:defaultValue="false" />

        <ListPreference
            android:key="webrtc_mode"
            android:title="@string/webrtc_mode"
            android:entries="@array/webrtc_mode_entries"
            android:entryValues="@array/webrtc_mode_values"
            android:defaultValue="disable" />

        <SwitchPreference
            android:key="doh_enabled"
            android:title="@string/doh_enabled"
            android:summary="@string/doh_enabled_summary"
            android:defaultValue="false" />

        <ListPreference
            android:key="doh_provider"
            android:title="@string/doh_provider"
            android:entries="@array/doh_provider_entries"
            android:entryValues="@array/doh_provider_values"
            android:defaultValue="https://cloudflare-dns.com/dns-query"
            android:dependency="doh_enabled" />

    </PreferenceCategory>

    <PreferenceCategory
        android:key="toolbar_button_actions"
        android:title="@string/toolbar_button_actions">

        <ListPreference
            android:key="back_button_long_press"
            android:title="@string/back_button_long_press"
            android:entries="@array/long_press_action_entries"
            android:entryValues="@array/long_press_action_values"
            android:defaultValue="none" />

        <ListPreference
            android:key="forward_button_long_press"
            android:title="@string/forward_button_long_press"
            android:entries="@array/long_press_action_entries"
            android:entryValues="@array/long_press_action_values"
            android:defaultValue="none" />

        <ListPreference
            android:key="home_button_long_press"
            android:title="@string/home_button_long_press"
            android:entries="@array/long_press_action_entries"
            android:entryValues="@array/long_press_action_values"
            android:defaultValue="none" />

        <ListPreference
            android:key="tabs_button_long_press"
            android:title="@string/tabs_button_long_press"
            android:entries="@array/long_press_action_entries"
            android:entryValues="@array/long_press_action_values"
            android:defaultValue="none" />

        <ListPreference
            android:key="menu_button_long_press"
            android:title="@string/menu_button_long_press"
            android:entries="@array/long_press_action_entries"
            android:entryValues="@array/long_press_action_values"
            android:defaultValue="none" />

    </PreferenceCategory>

</PreferenceScreen>
