<?xml version="1.0" encoding="utf-8"?>
<!-- One item in the floating 2x5 grid -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/floating_menu_item_size"
    android:layout_height="@dimen/floating_menu_item_size"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/floating_menu_item_bg"
    android:padding="8dp"
    android:margin="4dp">

    <ImageView
        android:id="@+id/menu_item_icon"
        android:layout_width="@dimen/floating_menu_icon_size"
        android:layout_height="@dimen/floating_menu_icon_size"
        android:scaleType="fitCenter"
        android:tint="@color/icon_active" />

    <TextView
        android:id="@+id/menu_item_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
