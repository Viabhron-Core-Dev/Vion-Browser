<?xml version="1.0" encoding="utf-8"?>
<!-- Single tab card in the tab tray -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="100dp"
    android:orientation="vertical"
    android:background="@drawable/floating_menu_item_bg"
    android:padding="8dp"
    android:layout_marginEnd="8dp">

    <!-- Title row + close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/tab_favicon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_tab_default"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tab_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/tab_close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close_tab"
            android:tint="@color/icon_inactive"
            android:padding="2dp" />

    </LinearLayout>

    <!-- Active indicator bar -->
    <View
        android:id="@+id/tab_active_indicator"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/vion_accent"
        android:layout_marginTop="2dp"
        android:visibility="invisible" />

    <!-- URL -->
    <TextView
        android:id="@+id/tab_url"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
