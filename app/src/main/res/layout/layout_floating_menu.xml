<?xml version="1.0" encoding="utf-8"?>
<!-- Floating menu container: ViewPager2 + dot indicator -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/floating_menu_padding">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/floating_menu_pager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/floating_menu_indicator"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        app:tabBackground="@drawable/tab_badge_background"
        app:tabIndicatorHeight="0dp"
        app:tabGravity="center"
        app:tabMinWidth="8dp"
        app:tabMaxWidth="8dp"
        app:tabPaddingStart="4dp"
        app:tabPaddingEnd="4dp"
        android:visibility="gone" />

</LinearLayout>
