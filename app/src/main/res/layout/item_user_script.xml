<?xml version="1.0" encoding="utf-8"?>
<!--
  item_user_script.xml — One row in the UserScript manager list.
  Binding class: ItemUserScriptBinding
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#16213E"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/script_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E8E8FF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/script_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9090A8"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <!-- Run-at badge -->
            <TextView
                android:id="@+id/script_run_at"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/tab_badge_background"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Edit button -->
        <ImageButton
            android:id="@+id/btn_edit_script"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu_settings"
            android:tint="#9D97FF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit_script" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btn_delete_script"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:tint="#FF6B6B"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete" />

        <!-- Enable / disable toggle -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/script_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
