<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppCompat / Material base theme -->
    <style name="VionBrowser" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/vion_primary</item>
        <item name="colorPrimaryDark">@color/vion_primary_dark</item>
        <item name="colorAccent">@color/vion_accent</item>
        <item name="android:windowBackground">@color/vion_primary_dark</item>
        <item name="android:statusBarColor">@color/vion_primary_dark</item>
        <item name="android:navigationBarColor">@color/bottom_bar_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="VionBrowser.MainWebView" parent="VionBrowser">
        <item name="android:windowTranslucentStatus">false</item>
    </style>

    <style name="VionBrowser.Settings" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/vion_primary</item>
        <item name="colorPrimaryDark">@color/vion_primary_dark</item>
        <item name="colorAccent">@color/vion_accent</item>
        <item name="android:windowBackground">@color/vion_primary_dark</item>
    </style>

    <style name="VionBrowser.About" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/vion_primary</item>
        <item name="colorPrimaryDark">@color/vion_primary_dark</item>
        <item name="colorAccent">@color/vion_accent</item>
        <item name="android:windowBackground">@color/vion_primary_dark</item>
    </style>

    <!-- Popup / overflow menu -->
    <style name="VionBrowser.PopupOverlay" parent="ThemeOverlay.AppCompat.Dark" />

    <!-- AppBar overlay -->
    <style name="VionBrowser.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- Floating menu item text -->
    <style name="FloatingMenuItemText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- URL bar EditText -->
    <style name="UrlBarEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/url_text</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- Full-height BottomSheetDialog (for Unified Panel — Phase 6) -->
    <style name="FullHeightBottomSheet" parent="Theme.Design.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/FullHeightBottomSheetStyle</item>
    </style>

    <style name="FullHeightBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@color/vion_primary_dark</item>
        <item name="behavior_peekHeight">600dp</item>
        <item name="behavior_hideable">true</item>
        <item name="behavior_skipCollapsed">true</item>
    </style>

    <!-- Floating menu item icon background (used by shortcut item) -->
    <style name="FloatingMenuItemBg">
        <item name="android:background">@drawable/floating_menu_item_bg</item>
    </style>
</resources>
